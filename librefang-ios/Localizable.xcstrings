    "The iPhone is offline, so the monitoring snapshot may be stale until connectivity returns.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这台 iPhone 当前离线，因此监控快照在恢复联网前可能过期。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone はオフラインのため、接続が戻るまで監視スナップショットは古い可能性があります。"
          }
        }
      }
    },
    "The mobile queue is showing \\(visibleCount) of \\(totalCount) pending approvals.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动队列当前显示 \\(totalCount) 个待处理审批中的 \\(visibleCount) 个。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モバイルキューには \\(totalCount) 件の保留承認のうち \\(visibleCount) 件が表示されています。"
          }
        }
      }
    },
    "The mobile queue is showing all \\(visibleCount) pending approvals.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动队列当前显示全部 \\(visibleCount) 个待处理审批。"
