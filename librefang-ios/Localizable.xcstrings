          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのツールを表示"
          }
        }
      }
    },
    "The filtered profile catalog stays compact before the full profile directory.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在完整配置目录前，筛选后的配置目录会保持紧凑。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィルター済みのプロファイルカタログは完全なプロファイルディレクトリの前でコンパクトなままです。"
          }
        }
      }
    },
    "The selected tool profile stays compact before the full profile tool list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在完整配置工具列表前，已选工具配置会保持紧凑。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択中のツールプロファイルは完全なプロファイルツール一覧の前でコンパクトなままです。"
          }
        }
      }
    },
    "Tool profiles explain what the runtime is allowed to call.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工具配置说明运行时被允许调用什么。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ツールプロファイルは、ランタイムが何を呼び出せるかを示します。"
          }
        }
      }
    },
    "Tool-profile focus coverage is currently anchored by dense bundled tool sets.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工具配置焦点覆盖当前由密集的捆绑工具集合主导。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
