    "At a Glance is showing \\(visibleCount) of \\(totalCount) live standby cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "概览当前显示 \\(visibleCount) / \\(totalCount) 张实时待命卡片。"
