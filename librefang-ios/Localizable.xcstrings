    "Tool profiles are server-defined bundles. They explain what an agent can and cannot call even when the rest of the runtime looks healthy." : {
      "comment" : "A description of what tool profiles are and their purpose.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツールプロファイルはサーバー定義のバンドルです。ランタイムの他の部分が健全でも、エージェントが何を呼べて何を呼べないかを示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "工具配置档是服务端定义的组合，用来说明即使运行时其他部分看起来健康时，智能体仍能和不能调用什么。"
          }
        }
      }
    },
    "Tool profiles explain what the runtime is allowed to call." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ツールプロファイルは、ランタイムが何を呼び出せるかを示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "工具配置说明运行时被允许调用什么。"
          }
        }
      }
    },
