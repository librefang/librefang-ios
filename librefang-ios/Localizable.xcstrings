    },
    "Keep risk spread and agent breadth visible before the compact approval rows or the full queue view.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在紧凑审批行或完整队列视图之前，先让风险分布和代理覆盖范围保持可见。"
          }
