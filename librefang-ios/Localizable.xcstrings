          }
        }
      }
    },
    "Keep queue, critical load, live alerts, and checklist progress visible before reading the shift notes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读班次备注前，让队列、严重负载、实时告警和检查清单进度保持可见。"
          }
