            "value": "フリート"
          }
        }
      }
    },
    "Incident action readiness is currently anchored by handoff follow-through and muted-alert drag.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件操作就绪度当前由交接跟进和静音告警拖拽主导。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インシデントのアクション準備状況は現在、引き継ぎの追従とミュートアラートの重さが軸です。"
          }
        }
      }
    },
    "Incident action readiness is currently anchored by live alert pressure and the next triage exits.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件操作就绪度当前由实时告警压力和下一步分诊出口主导。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インシデントのアクション準備状況は現在、ライブアラート負荷と次のトリアージ出口が軸です。"
          }
        }
      }
    },
    "Incident action readiness is currently calm enough for route review and queue maintenance.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件操作就绪度当前足够平静，可进行路由审查和队列维护。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インシデントのアクション準備状況は現在、ルート確認とキュー保守に進める程度に落ち着いています。"
          }
        }
      }
    },
    "Incident action readiness is currently centered on route breadth and queue coverage.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件操作就绪度当前围绕路由广度和队列覆盖展开。"
          }
        },
        "ja": {
          "stringUnit": {
