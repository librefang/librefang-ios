    "Use the compact queue slice to judge volume, labeling debt, and duplicate-agent spread before opening the rows.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开各行前，使用紧凑队列切片判断体量、标签欠账和重复代理分布。"
