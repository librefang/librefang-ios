    "Active severity and alert type spread stay summarized here before the per-alert controls.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在逐条告警控件展开之前，活跃严重度和告警类型分布会先在这里汇总。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アラートごとのコントロールに入る前に、アクティブな重大度とアラート種別の広がりがここで要約されます。"
          }
        }
      }
    },
