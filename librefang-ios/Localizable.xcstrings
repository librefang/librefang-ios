    "Jump to lower overview sections without long thumb-scrolling.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需长距离滚动即可跳到下方概览分区。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "長くスクロールせずに下位の概要セクションへジャンプします。"
          }
        }
      }
    },
    "Keep accumulated spend, total traffic, and call volume visible without another full-width totals row.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需额外的全宽总计行，也能让累计支出、总流量和调用量保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別の全幅合計行がなくても、累積支出、総トラフィック、コール量を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep active workflow depth and scheduler pressure visible before opening the automation monitor.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开自动化监控前，保持活跃工作流深度和调度压力可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動化モニターを開く前に、アクティブなワークフローの深さとスケジューラ負荷を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep connection, queue, and pressure visible before opening the overview cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开概览卡片前，让连接状态、队列和压力信息保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概要カードを開く前に、接続、キュー、負荷を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep database, warning, and supervisor pressure visible before opening the deep diagnostics view.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开深度诊断视图前，保持数据库、告警和 supervisor 压力可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深い診断ビューを開く前に、データベース、警告、supervisor の負荷を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep hourly, daily, and monthly spend visible without leaving the overview grid.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需离开概览网格，也能让每小时、每日和每月支出保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概要グリッドを離れずに、時間ごと・日次・月次の支出を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep live, muted, and acknowledgement state visible before reading each alert row.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读每条告警行前，让实时、静音和确认状态保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各アラート行を読む前に、ライブ、ミュート、確認状態を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep model, channel, hand, approval, peer, and tooling readiness visible without a long mobile list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需拉出很长的移动端列表，也能让模型、渠道、执行手、审批、对等体和工具就绪度保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "長いモバイル一覧がなくても、モデル、チャネル、ハンド、承認、ピア、ツーリングの準備状況を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep model, provider, peer, usage, and security context visible before opening deeper overview cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开更深层的概览卡片前，保持模型、provider、对等体、用量和安全上下文可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より深い概要カードを開く前に、モデル、provider、ピア、使用状況、セキュリティ文脈を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep muted alerts, follow-up load, diagnostics noise, and provider or channel readiness visible before the broader overview cards fan out.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在更宽的概览卡片展开前，让静音告警、跟进负载、诊断噪声以及提供方或通道就绪度保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より広い概要カードが展開する前に、ミュートアラート、フォローアップ負荷、診断ノイズ、provider またはチャネルの準備状況を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep muted drag, handoff follow-up, diagnostics noise, and slower systems pressure visible before the overview fans out into platform and fleet cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在概览展开到平台和机群卡片前，让静音拖拽、交接跟进、诊断噪声和较慢的系统压力保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概要がプラットフォームカードとフリートカードへ広がる前に、ミュートの滞留、引き継ぎフォローアップ、診断ノイズ、より遅いシステム負荷を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep pending approvals and active hands visible without opening the deeper runtime queues.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需打开更深的 runtime 队列，也能让待处理审批和活跃执行手保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より深い runtime キューを開かずに、保留承認とアクティブなハンドを見えるまま保ちます。"
          }
        }
      }
    },
    "Keep pinned-agent pressure and diagnostic issues visible before opening the fleet list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开机群列表前，保持已固定 agent 的压力和诊断问题可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フリート一覧を開く前に、固定済み agent の負荷と診断問題を見えるまま保ちます。"
          }
        }
      }
    },
    "Keep platform state, live signal drag, and fleet follow-through readable before moving into the wider overview cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进入更宽的概览卡片前，让平台状态、实时信号拖拽和机群跟进保持清晰可读。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より広い概要カードへ進む前に、プラットフォーム状態、ライブシグナルの滞留、フリートのフォロースルーを読みやすく保ちます。"
          }
        }
      }
    },
    "Keep platform, signal, and fleet coverage visible before the overview cards fan out below the entry deck.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在概览卡片于入口卡片下方展开前，让平台、信号和机群覆盖保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エントリーデッキ下で概要カードが広がる前に、プラットフォーム、シグナル、フリートのカバレッジを見えるまま保ちます。"
          }
        }
      }
    },
    "Keep provider, channel, and model drift pressure visible before opening the integration monitor.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开集成监控前，保持 provider、渠道和模型漂移压力可见。"
          }
