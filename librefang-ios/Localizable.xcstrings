          }
        }
      }
    },
    "Keep credential gaps, quick-setup surface area, and probe activity visible before dropping into the full channel list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进入完整渠道列表前，保持凭据缺口、快速设置范围和探测活动可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完全なチャネル一覧に入る前に、認証情報不足、クイックセットアップ範囲、プローブ活動を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep provider coverage, local reachability, and live probe state visible before the longer provider rows take over.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在更长的提供方行展开前，保持提供方覆盖、本地可达性和实时探测状态可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "長いプロバイダ行が続く前に、プロバイダカバレッジ、ローカル到達性、ライブプローブ状態を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep provider, channel, catalog, and agent-drift counts visible before diving into the inventory.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在深入清单前，保持提供方、渠道、目录和代理漂移计数可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一覧に入る前に、プロバイダ、チャネル、カタログ、エージェントドリフト件数を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep provider, channel, model, alias, and drift coverage visible before the jump rail and operator routes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在跳转轨和运维路由之前，保持提供方、渠道、模型、别名和漂移覆盖可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ジャンプレールとオペレータールートの前に、プロバイダ、チャネル、モデル、エイリアス、ドリフトのカバレッジを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep readiness, setup depth, and missing field pressure visible before opening each channel row.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开各渠道行前，保持就绪度、设置深度和缺失字段压力可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各チャネル行を開く前に、準備状況、設定深度、必須項目不足を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep route breadth, jump coverage, and integration inventory depth visible before drilling into provider, channel, model, and drift details.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在深入提供方、渠道、模型和漂移细节前，保持路由广度、跳转覆盖和集成清单深度可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ、チャネル、モデル、ドリフト詳細に入る前に、ルートの広さ、ジャンプカバレッジ、統合一覧の深さを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep scope, attention filters, and highest-signal integration counts in one compact digest.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将范围、关注过滤器和高信号集成计数集中在一个紧凑摘要中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スコープ、注目フィルタ、高シグナルの統合件数を 1 つのコンパクトな要約にまとめます。"
          }
        }
      }
    },
    "Keep search scope, inventory breadth, and the loudest provider, channel, catalog, and drift buckets readable before opening routes and jumps.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开路由和跳转前，保持搜索范围、清单广度以及最显著的提供方、渠道、目录和漂移压力可读。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルートとジャンプを開く前に、検索範囲、一覧の広さ、主要なプロバイダ、チャネル、カタログ、ドリフトの圧力を読みやすく保ちます。"
          }
        }
      }
    },
    "Keep section coverage visible before jumping around the integration inventory.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在集成清单中跳转前，保持分区覆盖可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統合一覧内を移動する前に、セクションカバレッジを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep slower spend, automation, and routing drilldowns behind the primary exits.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将较慢的支出、自动化和路由下钻放在主出口之后。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "低速な支出、自動化、ルーティングの深掘りは主要導線の後ろに置きます。"
          }
        }
      }
    },
    "Keep the next operator exits compact and visible above the provider, channel, and drift inventory.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将下一个运维出口保持紧凑并显示在提供方、渠道和漂移清单上方。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のオペレータ導線をコンパクトに保ち、プロバイダ、チャネル、ドリフト一覧の上に表示します。"
          }
        }
      }
    },
    "Keep unknown models, unavailable catalog entries, and provider mismatch spread visible before opening affected agents.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开受影响代理前，保持未知模型、不可用目录条目和提供方不匹配分布可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "影響を受けるエージェントを開く前に、未知モデル、利用不可カタログ項目、プロバイダ不一致の広がりを見える状態に保ちます。"
          }
        }
      }
    },
