          }
        }
      }
    },
    "Keep availability, provider spread, and tool-capable catalog depth visible before scanning the model list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在浏览模型列表前，保持可用性、提供方分布和工具能力目录深度可见。"
