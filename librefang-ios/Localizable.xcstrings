      }
    },
    "Keep readiness, usage, spend, and live workload visible before the signal cards start stacking.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在信号卡片开始堆叠前，让就绪度、用量、花费和实时负载保持可见。"
