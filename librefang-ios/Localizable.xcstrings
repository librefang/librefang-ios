        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のダッシュボードスナップショットには未解決の承認ゲートがありません。"
          }
        }
      }
    },
    "The current mobile monitoring snapshot does not show blocked actions, critical events, unhealthy agents, or overdue local handoff checkpoints.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前移动监控快照中没有阻塞操作、严重事件、不健康代理或逾期的本地交接检查点。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のモバイル監視スナップショットには、ブロックされたアクション、重大イベント、不健全なエージェント、期限超過のローカル引き継ぎチェックポイントは表示されていません。"
          }
        }
      }
    },
    "The dashboard has not refreshed for more than two minutes.": {
