        }
      }
    },
    "Incident controls are grouping \\(primaryRouteCount) primary routes and \\(supportRouteCount) support routes before the queue.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进入队列之前，事件控件会先分组显示 \\(primaryRouteCount) 个主路由和 \\(supportRouteCount) 个辅助路由。"
