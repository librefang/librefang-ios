          }
        }
      }
    },
    "Keep credential gaps, quick-setup surface area, and probe activity visible before dropping into the full channel list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进入完整渠道列表前，保持凭据缺口、快速设置范围和探测活动可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完全なチャネル一覧に入る前に、認証情報不足、クイックセットアップ範囲、プローブ活動を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep provider coverage, local reachability, and live probe state visible before the longer provider rows take over.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在更长的提供方行展开前，保持提供方覆盖、本地可达性和实时探测状态可见。"
          }
        },
        "ja": {
          "stringUnit": {
