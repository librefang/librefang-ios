          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドリフト概要"
          }
        }
      }
    },
    "Integration action readiness is currently anchored by model or provider drift that is ready for deeper drilldown.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "集成行动就绪度当前主要受模型或提供方漂移影响，适合继续深入排查。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統合アクション準備度は現在、さらに掘り下げ可能なモデルまたはプロバイダのドリフトに左右されています。"
          }
        }
      }
    },
    "Integration action readiness is currently clear enough for route jumps and inventory review.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前已足够清晰，可直接进入路由跳转和清单检查。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在は十分に明確で、ルートジャンプと一覧確認に進めます。"
          }
        }
      }
    },
    "Integration action readiness is currently narrowed by an active search scope.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前受活动搜索范围限制。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在は有効な検索範囲によって絞り込まれています。"
          }
        }
      }
    },
    "Integration pressure is currently anchored by provider reachability or agent model drift.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "集成压力当前主要来自提供方可达性或代理模型漂移。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "連携圧力は現在、プロバイダ到達性またはエージェントモデルドリフトに集中しています。"
          }
        }
      }
    },
    "Integration pressure is currently concentrated in channel setup gaps and catalog availability.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "集成压力当前集中在渠道设置缺口和目录可用性。"
