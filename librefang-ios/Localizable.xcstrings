          }
        }
      }
    },
    "Keep routes, jumps, and section coverage readable before the overview fans out into platform, signal, and fleet cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在概览展开到平台、信号和机群卡片前，让路由、跳转和分区覆盖保持清晰可读。"
          }
