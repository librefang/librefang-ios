          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cue オン"
          }
        }
      }
    },
    "Dashboard refresh is set to every \\(refreshInterval) seconds.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仪表盘刷新当前设置为每 \\(refreshInterval) 秒一次。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダッシュボードの更新は現在 \\(refreshInterval) 秒ごとに設定されています。"
          }
        }
      }
    },
    "Device-local monitoring state stays visible here before the longer per-signal rows.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备本地监控状态会先显示在这里，再展开更长的逐信号行。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスローカルの監視状態は、より長いシグナル別の行より前にここで確認できます。"
          }
        }
      }
    },
    "Keep address scope, auth state, and current server reachability visible before editing connection fields.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在编辑连接字段前，先让地址范围、认证状态和当前服务器可达性保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続項目を編集する前に、アドレス範囲、認証状態、現在のサーバー到達性を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep authorization, arming scope, and any queued reminder visible before adjusting standby reminder controls.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在调整待命提醒控件前，先让授权、启用范围和任何排队中的提醒保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "待機リマインダーの設定を調整する前に、認可、対象範囲、キュー済みリマインダーを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep device readiness, reminder state, and low-frequency monitoring context visible before the settings form expands into controls and toggles.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置表单展开为控件和开关之前，先让设备就绪度、提醒状态和低频监控上下文保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定フォームがコントロールやトグルへ広がる前に、デバイスの準備状態、リマインダー状態、低頻度監視の文脈を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep device sections, queued reminders, and on-call pressure visible before the longer settings form opens up.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在更长的设置表单展开前，先让设备分区、排队提醒和值班压力保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より長い設定フォームを開く前に、デバイスの各セクション、キュー済みリマインダー、オンコール負荷を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep mobile readiness, queue pressure, and reminder state readable before opening the full settings form.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开完整设置表单前，先让移动端就绪度、队列压力和提醒状态保持可读。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完全な設定フォームを開く前に、モバイルの準備状態、キュー負荷、リマインダー状態を読みやすく保ちます。"
          }
        }
      }
    },
    "Keep reminders, handoff state, monitoring summary, and app metadata behind the primary jumps.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让提醒、交接状态、监控摘要和应用元数据留在主跳转之后。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リマインダー、引き継ぎ状態、監視サマリー、アプリのメタデータは主要ジャンプの後ろにまとめます。"
          }
        }
      }
    },
    "Keep route exits, device controls, and live monitoring load visible before the server, reminder, handoff, and monitoring settings expand into the full form.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在服务器、提醒、交接和监控设置展开为完整表单前，先让路由出口、设备控件和实时监控负载保持可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバー、リマインダー、引き継ぎ、監視の設定が完全なフォームに広がる前に、ルート出口、デバイスコントロール、ライブ監視負荷を見える状態に保ちます。"
          }
        }
      }
    },
    "Keep runtime and diagnostics behind the primary shift-management exits.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让运行时和诊断位于主要排班管理出口之后。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムと診断は主要なシフト管理の出口の後ろにまとめます。"
          }
        }
      }
    },
    "Keep secondary runtime catalogs and external-agent routes close without letting them crowd the primary control deck.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让次级运行时目录和外部代理路由保持靠近，但不要挤占主控卡片。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "補助ランタイムカタログと外部エージェントのルートは近くに置きつつ、主要コントロールデッキを圧迫しないようにします。"
          }
        }
      }
    },
    "Keep snapshot, routes, and device controls together before the longer settings form.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在更长的设置表单前，先把快照、路由和设备控件放在一起。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より長い設定フォームの前に、スナップショット、ルート、デバイスコントロールをまとめておきます。"
          }
        }
      }
    },
    "Keep the active locale and supported catalog visible before leaving the app for system language settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在离开应用前往系统语言设置之前，先让当前语言环境和支持的目录保持可见。"
          }
