          }
        }
      }
    },
    "Incident support coverage is currently anchored by muted alert drag, handoff load, and watched diagnostics.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件辅助覆盖当前由静音告警拖拽、交接负载和关注诊断主导。"
