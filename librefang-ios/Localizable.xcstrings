    },
    "Kernel \\(status.localizedStatusLabel) with \\(status.agentCount) agents and \\(vm.pendingApprovalCount) pending approvals in the current runtime snapshot.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
