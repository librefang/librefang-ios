    },
    "Keep auth readiness, local reachability, and discovered model depth visible before the longer provider list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在查看更长的提供方列表前，保持认证准备度、本地可达性和已发现模型深度可见。"
          }
        },
        "ja": {
          "stringUnit": {
