    "Use delivery receipts to confirm whether outbound channel sends actually reached a recipient or failed downstream.": {
      "comment": "A footer label explaining the purpose of the \"Deliveries\" section in the agent detail view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
