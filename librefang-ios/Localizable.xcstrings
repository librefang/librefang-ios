    },
    "The route rail stays compact while the fleet list is search-scoped.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在代理群列表被搜索范围收窄时，路由栏会保持紧凑。"
          }
