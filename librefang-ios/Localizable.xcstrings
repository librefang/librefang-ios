    "Integration pressure spans \\(issueCategoryCount) issue classes in the incident queue.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "集成压力当前在事件队列中覆盖 \\(issueCategoryCount) 个问题类别。"
