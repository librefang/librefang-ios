          }
        }
      }
    },
    "Keep route breadth, jump coverage, and integration inventory depth visible before drilling into provider, channel, model, and drift details.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在深入提供方、渠道、模型和漂移细节前，保持路由广度、跳转覆盖和集成清单深度可见。"
          }
