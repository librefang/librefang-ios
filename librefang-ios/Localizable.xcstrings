          }
        }
      }
    },
    "Keep slower infrastructure and secondary drilldowns behind the primary buckets.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让较慢的基础设施项和次级下钻位于主分桶之后。"
