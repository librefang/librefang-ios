        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルートとセクションジャンプは、プロバイダ、チャネル、モデル、ドリフト一覧の前にここで要約表示されます。"
          }
        }
      }
    },
    "Search active": {
