          }
        }
      }
    },
    "Routes and section jumps stay summarized here before provider, channel, model, and drift inventories.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "路由和分区跳转会先在这里汇总，再进入提供方、渠道、模型和漂移清单。"
          }
