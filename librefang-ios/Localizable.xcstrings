    },
    "Use fleet context when approval requests cluster around the same agents." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "承認要求が同じエージェント群に集中している場合は、フリート文脈を使います。"
