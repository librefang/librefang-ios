          }
        }
      }
    },
    "Keep provider, channel, model, alias, and drift coverage visible before the jump rail and operator routes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在跳转轨和运维路由之前，保持提供方、渠道、模型、别名和漂移覆盖可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ジャンプレールとオペレータールートの前に、プロバイダ、チャネル、モデル、エイリアス、ドリフトのカバレッジを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep readiness, setup depth, and missing field pressure visible before opening each channel row.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开各渠道行前，保持就绪度、设置深度和缺失字段压力可见。"
