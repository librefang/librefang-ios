        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アラートインベントリ"
          }
        }
      }
    },
    "Alerts, approvals, sessions, events, automation, integrations, and handoff pressure stay grouped before the routes fan out.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在路由展开之前，告警、审批、会话、事件、自动化、集成和交接压力会先分组显示。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルートが広がる前に、アラート、承認、セッション、イベント、自動化、統合、引き継ぎの負荷がまとめて表示されます。"
          }
        }
      }
    },
    "Automation inventory": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动化清单"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動化インベントリ"
          }
        }
      }
    },
    "Automation pressure is currently quiet in the incident queue.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动化压力当前在事件队列中较为平静。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動化の負荷は現在、インシデントキューでは落ち着いています。"
          }
        }
      }
    },
    "Automation pressure spans \\(issueCategoryCount) issue classes in the incident queue.": {
      "localizations": {
