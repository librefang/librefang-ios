          }
        }
      }
    },
    "Tool-profile focus coverage is currently anchored by the filtered profile catalog.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工具配置焦点覆盖当前由筛选后的配置目录主导。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
