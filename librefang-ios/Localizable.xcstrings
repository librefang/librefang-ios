          }
        }
      }
    },
    "Tool-profile focus coverage is currently anchored by the selected profile and its bundled tools.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工具配置焦点覆盖当前由已选配置及其捆绑工具主导。"
          }
        },
        "ja": {
          "stringUnit": {
