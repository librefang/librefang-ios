          }
        }
      }
    },
    "Keep feed readiness, recovery drag, and leaderboard depth readable before moving into deep health, build, config, and metrics sections.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进入深层健康、构建、配置和指标分区前，保持 feed 就绪度、恢复滞留和排行榜深度可读。"
          }
