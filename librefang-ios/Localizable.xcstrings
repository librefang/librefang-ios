    "Use broader runtime context when memory alone is not enough." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当仅靠记忆不足时，使用更广的运行时上下文。"
          }
        }
      }
    },
    "Use comms and runtime surfaces first." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "まず通信とランタイムの画面を使ってください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "优先使用通信和运行时界面。"
          }
        }
      }
    },
    "Use deeper diagnostics and routing checks when spend concentration hints at runtime drift." : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当支出集中度暗示运行时漂移时，使用更深入的诊断和路由检查。"
          }
        }
      }
    },
    "Use delivery receipts to confirm whether outbound channel sends actually reached a recipient or failed downstream." : {
      "comment" : "A footer label explaining the purpose of the \"Deliveries\" section in the agent detail view.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用投递回执来确认出站渠道发送是否真正送达接收方，或在下游失败。"
          }
        }
      }
    },
    "Use fleet and runtime surfaces first." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "まずフリートとランタイムの画面を使ってください。"
