    "High-volume, unlabeled, and duplicated sessions stay visible before the list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在列表开始前，高流量、未标注和重复会话会保持可见。"
