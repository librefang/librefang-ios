          "stringUnit": {
            "state": "translated",
            "value": "より遅い支出と設定ルートは二次レールに保ちます。"
          }
        }
      }
    },
    "Keep system, diagnostics, integrations, and automation grouped before the platform cards begin.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在平台卡片开始展开前，将系统、诊断、集成和自动化分组展示。"
