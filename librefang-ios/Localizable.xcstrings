        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルートとジャンプを開く前に、検索範囲、一覧の広さ、主要なプロバイダ、チャネル、カタログ、ドリフトの圧力を読みやすく保ちます。"
          }
        }
