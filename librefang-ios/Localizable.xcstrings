          }
        }
      }
    },
    "Tool-profile focus coverage is currently balanced across the visible profile catalog.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工具配置焦点覆盖当前在可见配置目录中保持平衡。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
