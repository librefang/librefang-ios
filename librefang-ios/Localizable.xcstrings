        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一目でわかる表示には現在、ライブな待機カード \\(totalCount) 件中 \\(visibleCount) 件が表示されています。"
          }
        }
      }
    },
    "At a Glance is showing all \\(visibleCount) live standby cards.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "概览当前显示全部 \\(visibleCount) 张实时待命卡片。"
