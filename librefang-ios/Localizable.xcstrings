          }
        }
      }
    },
    "Keep the dominant settings lane readable before moving from compact device readiness decks into the full control form.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从紧凑的设备就绪卡片切换到完整控件表单前，先让主设置通道保持可读。"
