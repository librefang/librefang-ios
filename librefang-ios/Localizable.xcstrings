          }
        }
      }
    },
    "These commands affect the active session on the server. Use them after confirming the current agent state.": {
      "comment": "A footer explaining the purpose of the session controls in the `AgentDetailView`.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
