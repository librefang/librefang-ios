          }
        }
      }
    },
    "Keep deep-diagnostic coverage visible before the long health, build, config, metrics, and leaderboard sections take over.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在长篇的健康、构建、配置、指标和排行榜分区接管前，保持深度诊断覆盖可见。"
          }
