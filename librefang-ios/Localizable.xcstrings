          }
        }
      }
    },
    "Use this deck to gauge whether the current slice is dominated by hotspots, unlabeled sessions, or duplicate-agent churn.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
