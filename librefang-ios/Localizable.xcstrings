          }
        }
      }
    },
    "The current dashboard snapshot has no unresolved approval gates.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前仪表盘快照没有未解决的审批关卡。"
