          }
        }
      }
    },
    "Jump to the alias map that resolves requested model names into catalog models.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳转到将请求模型名解析到目录模型的别名映射。"
