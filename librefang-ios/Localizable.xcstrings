    "Providers, channels, models, aliases, and drift stay summarized before the jump rail and deeper operator routes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提供方、渠道、模型、别名和漂移会在跳转轨和更深的运维路由前保持汇总。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ、チャネル、モデル、エイリアス、ドリフトはジャンプレールと深いオペレータールートの前で要約表示されます。"
          }
        }
      }
    },
    "Routes": {
