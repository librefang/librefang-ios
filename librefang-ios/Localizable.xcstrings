    },
    "Search by action, detail, or agent to narrow the event stream.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按操作、详情或代理搜索，以缩小事件流范围。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "操作、詳細、またはエージェントで検索してイベントストリームを絞り込みます。"
          }
        }
      }
    },
    "Search is narrowed to \\\"\\(searchText)\\\", so only the matching approval slice stays in the mobile queue.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索已收窄到“\\(searchText)”，因此移动队列中只保留匹配的审批切片。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検索は「\\(searchText)」に絞り込まれているため、モバイルキューには一致する承認断面だけが残ります。"
          }
        }
      }
    },
    "Severity mix, result volume, and transport mode stay summarized before the event feed takes over the page.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在事件流接管页面前，风险分布、结果量和传输模式会先保持汇总。"
          }
