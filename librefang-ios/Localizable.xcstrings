          }
        }
      }
    },
    "Jump around the incident buckets themselves without dragging through the entire list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接在事件分桶之间跳转，无需拖过整个列表。"
