    "Jump straight to the agent, session backlog, or durable memory without leaving the active conversation.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需离开当前对话，即可直接跳到代理、会话积压或持久记忆。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブな会話を離れずに、エージェント、セッションバックログ、または永続メモリへ直接移動します。"
          }
        }
      }
    },
    "Keep the most common agent, session, memory, workspace, and delivery drilldowns one tap away while staying in the current chat.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在当前聊天中，保持最常用的代理、会话、记忆、工作区和投递下钻都只需一跳。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のチャットに留まりながら、もっとも一般的なエージェント、セッション、メモリ、ワークスペース、配信のドリルダウンを 1 タップ先に保ちます。"
          }
        }
      }
    },
    "Keep transport mode, reply state, context load, and history coverage visible while the agent is still in session.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在代理仍处于会话中时，保持传输模式、回复状态、上下文负载和历史覆盖可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントがまだセッション中の間、転送モード、返信状態、コンテキスト負荷、履歴カバレッジを見えるまま保ちます。"
          }
        }
      }
    },
    "Keep workspace identity and outbound receipts close when the reply needs deeper operator verification.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当回复需要更深入的操作员验证时，让工作区身份和外发回执保持靠近。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "返信により深いオペレーター確認が必要な場合、ワークスペース ID と送信レシートを近くに保ちます。"
          }
        }
      }
    },
    "Loading recent conversation and session context.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
