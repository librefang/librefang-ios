    "Keep alias count and target coverage visible before scrolling the longer alias mapping list.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在滚动更长的别名映射列表前，保持别名数量和目标覆盖可见。"
          }
        },
        "ja": {
          "stringUnit": {
