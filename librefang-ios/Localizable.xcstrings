    },
    "Open the dedicated approval monitor when the compact incident list is not enough.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当紧凑事件列表不足以处理时，打开专用审批监视器。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
