        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統合一覧内を移動する前に、セクションカバレッジを見える状態に保ちます。"
          }
        }
      }
    },
    "Keep slower spend, automation, and routing drilldowns behind the primary exits.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
