    "The app connects to this base URL on launch and refreshes the dashboard immediately after you save.": {
      "comment": "A hint explaining that the app connects to a base URL on launch and refreshes the dashboard immediately after it is saved.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
