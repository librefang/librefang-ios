          }
        }
      }
    },
    "Keep the longest settings groups reachable on a single-handed mobile layout.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让最长的设置分组在单手移动布局中也能触达。"
