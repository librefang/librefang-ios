        }
      }
    },
    "Keep high-volume churn, label hygiene, and multi-session agent drag readable before drilling into individual sessions.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在深入单个会话前，保持高流量波动、标签整备和多会话代理拖累清晰可读。"
